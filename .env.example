# GhostTrack Environment Configuration
# Copy this file to .env and fill in the values

# Server
SYNC_PORT=3456
RUST_LOG=info

# Authentication
JWT_SECRET=change-me-in-production-generate-a-long-random-string

# Nginx
NGINX_HTTP_PORT=8080
NGINX_HTTPS_PORT=8443
SSL_CERT_PATH=./certs

# Data paths
DATA_DIR=/opt/ghosttrack/data
BACKUP_DIR=/opt/ghosttrack/backups

# Backup
BACKUP_RETENTION_DAYS=30
BACKUP_INTERVAL_HOURS=6

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
